# Copia este archivo a .env y ajusta los valores para tu entorno local.
# NUNCA subas .env al repositorio.

# Genera una clave segura con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-secreta-real

# True solo en desarrollo local
DEBUG=True

# Hosts permitidos (separados por coma, sin espacios)
ALLOWED_HOSTS=127.0.0.1,localhost

# Solo necesario en producción (ej. Render)
CSRF_TRUSTED_ORIGINS=

# Cadena de conexión PostgreSQL
# Formato: postgres://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=postgres://flotilla_user:flotilla_pass@localhost:5432/flotilla_db
